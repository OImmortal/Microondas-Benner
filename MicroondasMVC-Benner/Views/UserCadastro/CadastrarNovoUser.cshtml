@model MicroondasMVC_Benner.Models.API.UserAuthModel

@{
    ViewData["Title"] = "Cadastro de Usuário";
}

<form asp-controller="UserCadastro" method="post" class="container mt-5">
    <h2>Cadastro de Usuário para Autenticação</h2>
    <hr />

    @if (ViewBag.Mensagem != null)
    {
        <div class="alert alert-danger">@ViewBag.Mensagem</div>
    }

    <div class="form-group">
        <label>User</label>
        <input asp-for="User" type="text" class="form-control" placeholder="Informe o usuário">
    </div>
    <div class="form-group">
        <label>Senha</label>
        <input asp-for="Senha" type="password" class="form-control" id="exampleInputPassword1" placeholder="Informe uma Senha">
    </div>

    <br />

    <button asp-action="CadastrarNovoUser" type="submit" class="btn btn-primary">Cadastrar</button>
    <a asp-controller="MicroOndas" asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>